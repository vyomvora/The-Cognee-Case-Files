# Copy this file to .env and fill in your LLM provider details.
# llm_client.py reads these three variables and nothing else — swap providers
# freely without touching game code.

# Any string your provider client recognizes, e.g. "openai", "anthropic", "azure".
LLM_PROVIDER=openai

# Model name for that provider, e.g. "gpt-4o-mini", "claude-sonnet-5".
LLM_MODEL=gpt-4o-mini

# Secret key for the provider above.
LLM_API_KEY=

# Optional: only needed for providers/gateways that require a custom base URL.
LLM_BASE_URL=
